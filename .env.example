# Research Atlas — environment variables
# Copy this file to .env.local and fill in your values.
# ANTHROPIC_API_KEY is optional: if absent, Ask Atlas uses built-in fallback
# responses so the UI still works end-to-end.

# Optional — enables the live Ask Atlas AI assistant
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Paystack — powers both the existing /support page and the
# donation components in components/DonateCard.tsx.
# ─────────────────────────────────────────────────────────────

# Public key — safe to expose to the browser.
# Get it from: Paystack Dashboard → Settings → API Keys & Webhooks
# Used in: components/DonateCard.tsx, lib/payments/paystack.ts
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxx

# Secret key — SERVER-SIDE ONLY. Never expose this to the browser or commit
# your real value to version control.
# Get it from: Paystack Dashboard → Settings → API Keys & Webhooks
# Used in: app/api/paystack/verify/route.ts, app/api/verify-payment/route.ts
PAYSTACK_SECRET_KEY=sk_xxxxxxxxxxxxxxxxx
